#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# CONFIGURATION DEFINITIONS
# Format: "VAR_NAME:DEFAULT_VALUE:CLI_FLAG:CLI_VALUE:INTERACTIVE_PROMPT:HELP_DESCRIPTION"
# ==============================================================================
OPTIONS=(
    "USE_STATS:1:--disable-stats:0:Enable request stats?:Disable request statistics support at compile time"
    "USE_GEOIP:0:--use-geoip:1:Enable GeoIP module (IP2Location)?:Enable IP2Location GeoIP statistics"
    "EXIT_IF_STATS_FAIL_INITIALIZING:0:--exit-on-failed-stat-initialization:1:Fail if we fail to initialize stats?:Exit if stats initialization fails"
)

for opt in "${OPTIONS[@]}"; do
    IFS=':' read -r var default flag flag_value prompt desc <<< "$opt"
    printf -v "$var" "%s" "$default"
done

INTERACTIVE=0

print_help() {
    echo "Usage: ./configure [OPTIONS]"
    echo ""
    echo "Options:"
    for opt in "${OPTIONS[@]}"; do
        IFS=':' read -r var default flag flag_value prompt desc <<< "$opt"
        default_label="disabled"
        [[ "$default" == "1" ]] && default_label="enabled"
        printf "  %-38s %s (Default: %s)\n" "$flag" "$desc" "$default_label"
    done
    echo "  -i, --interactive  Run in interactive configuration mode"
    echo "  -h, --help         Show this help message"
    echo ""
    exit 0
}

validate() {
    if [[ "$USE_STATS" == 0 ]]; then
        USE_GEOIP=0
        EXIT_IF_STATS_FAIL_INITIALIZING=0
        return
    fi

    if [[ "$USE_GEOIP" == 1 && ! -f "third_party/IP2Location.c" ]]; then
        echo "Warning: third_party/IP2Location.c not found! Build might fail."
    fi
}

prompt_choice() {
    local prompt_text="$1"
    local default_ans="$2"
    local var_name="$3"

    local choice_hint="[y/N]"
    [[ "$default_ans" == "1" ]] && choice_hint="[Y/n]"

    local user_input
    read -p "$prompt_text $choice_hint: " user_input
    [[ -z "$user_input" ]] && user_input="$default_ans"

    case "${user_input,,}" in
        y|yes|1) printf -v "$var_name" "1" ;;
        n|no|0)  printf -v "$var_name" "0" ;;
        *)
            echo "Invalid choice, using default."
            printf -v "$var_name" "$default_ans"
            ;;
    esac
}

while [[ $# -gt 0 ]]; do
    matched=0
    for opt in "${OPTIONS[@]}"; do
        IFS=':' read -r var default flag flag_value prompt desc <<< "$opt"
        if [[ "$1" == "$flag" ]]; then
            printf -v "$var" "%s" "$flag_value"
            matched=1
            break
        fi
    done

    if [[ $matched -eq 1 ]]; then
        shift
        continue
    fi

    case $1 in
        -i|--interactive) INTERACTIVE=1 ;;
        -h|--help)        print_help ;;
        *)
            echo "Unknown option: $1"
            echo "Run ./configure --help for usage."
            exit 1
            ;;
    esac
    shift
done

if [[ "$INTERACTIVE" == 1 ]]; then
    echo "=== Server configure — interactive mode ==="
    echo ""
    for opt in "${OPTIONS[@]}"; do
        IFS=':' read -r var default flag flag_value prompt desc <<< "$opt"
        current_val="${!var}"
        prompt_choice "$prompt" "$current_val" "$var"
    done
    echo ""
fi

validate

cat > config.mk << EOF
# Generated by ./configure
# Re-run './configure' (or './configure -i') to change settings.

EOF

for opt in "${OPTIONS[@]}"; do
    IFS=':' read -r var default flag flag_value prompt desc <<< "$opt"
    val="${!var}"
    echo "$var = $val" >> config.mk
done

echo "Configuration generated natively in config.mk"
for opt in "${OPTIONS[@]}"; do
    IFS=':' read -r var default flag flag_value prompt desc <<< "$opt"
    echo "  $var=${!var}"
done
echo ""
echo "You can now run 'make'."
