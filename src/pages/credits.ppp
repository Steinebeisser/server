                <div class="source"><a href="https://www.uhdpaper.com/2023/01/riven-battle-bunny-granite-4k-8k-3390i.html?m=0" target="_blank" rel="noopener">UHD Paper</a> · underlying art © Riot Games, Inc.</div>
                <span class="license riot">© Riot Games</span>
            </div>
        </section>

        <section class="credit_section ark_studio_wildcard">
            <h2>ARK: Survival Ascended</h2>

            <div class="credit_item">
                <img class="credit_preview" src="[$ASSET:Alpha_Ascension_Implant.webp$]" alt="">
