                <div class="source"><a href="https://wiki.leagueoflegends.com" target="_blank" rel="noopener">League of Legends Wiki</a> · © Riot Games, Inc.</div>
                <span class="license riot">© Riot Games</span>
            </div>
            <div class="separator"></div>

            <div class="credit_item">
                <img class="credit_preview cover" src="[$ASSET:Riven_ValiantSwordSkin.jpg$]" alt="">
