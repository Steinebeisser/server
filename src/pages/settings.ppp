---
|route: /settings
|pagetitle: Stein Settings
---

<div class="settings_page">

    <div class="settings_section">
        <div class="settings_section_title">Audio</div>
        <div class="settings_section_content">
            <div class="settings_row">
                <label class="settings_label" for="vol-slider">Background Music Volume</label>
                <div class="settings_control">
                    <input type="range" id="vol-slider" class="vol_slider" min="0" max="100" value="10"
                        oninput="setVolume(this.value)">
                    <span class="vol_value" id="vol-display">10%</span>
                </div>
            </div>
        </div>
    </div>

    <div class="settings_section">
        <div class="settings_section_title">Color Scheme</div>
        <div class="settings_section_content">
            <div class="settings_row">
                <label class="settings_label">Theme</label>
                <div class="settings_control theme_buttons">
                    <button class="theme_btn" data-theme="gold" id="btn-gold" onclick="applyTheme('gold')">
                        <span class="theme_swatch" style="background:#c89b3c"></span>
                        Gold
                    </button>
                    <button class="theme_btn" data-theme="purple" id="btn-purple" onclick="applyTheme('purple')">
                        <span class="theme_swatch" style="background:#a855f7"></span>
                        Purple
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="settings_section">
        <div class="settings_section_title">Background</div>
        <div class="settings_section_content">
            <div class="settings_row">
                <label class="settings_label">Background Image</label>
                <div class="settings_control bg_buttons">
                    <button class="bg_btn" style="background-image: url('[$ASSET:battle-bunny-granite.webp$]')"
                        onclick="applyBackground('[$ASSET:battle-bunny-granite.webp$]')">
                    </button>
                    <button class="bg_btn" style="background-image: url('[$ASSET:Riven_ValiantSwordSkin.jpg$]')"
                        onclick="applyBackground('[$ASSET:Riven_ValiantSwordSkin.jpg$]')">
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    (function initSettings() {
        const slider = document.getElementById("vol-slider");
        const display = document.getElementById("vol-display");
        var savedVolume = localStorage.getItem("bg_music_volume");
        if (savedVolume !== null) {
            savedVolume = savedVolume * 100;
            slider.value = savedVolume;
            savedVolume = Math.floor(savedVolume);
            display.textContent = savedVolume + "%";
        }

        const savedBg = localStorage.getItem("bg_image");
        if (savedBg) {
            document.querySelectorAll(".bg_btn").forEach(btn => {
                btn.classList.toggle("active", btn.dataset.bg === savedBg);
            });
        }
    })();
</script>
